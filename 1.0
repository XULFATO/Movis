  }
}catch(e){msg='ERROR: '+e.message;}
console.warn(msg);
window.__ello=msg;
})();




VEMOS QUE HACE EL BOTON
(function(){
var msg='';
try{
  var d=window.frames[1].document;
  var imgs=d.getElementsByTagName('img');
  for(var i=0;i<imgs.length;i++){
    var img=imgs[i];
    var src=img.src||'';
    if(src.indexOf('libro')>-1||src.indexOf('book')>-1||src.indexOf('open')>-1||src.indexOf('consult')>-1){
      msg+='IMG src='+src+'\n';
      msg+='  onclick='+(img.getAttribute('onclick')||'ninguno')+'\n';
      var p=img.parentNode;
      msg+='  parent='+p.tagName+' onclick='+(p.getAttribute('onclick')||'ninguno')+' href='+(p.href||'ninguno')+'\n';
    }
  }
  // por si no lo pillamos por src, listar todos los clickables del header
  var as=d.getElementsByTagName('a');
  for(var i=0;i<as.length;i++){
    var a=as[i];
    msg+='A href='+(a.href||'')+' onclick='+(a.getAttribute('onclick')||'')+' title='+(a.title||'')+'\n';
  }
}catch(e){msg='ERROR: '+e.message;}
console.warn(msg);
window.__btn=msg;
})();






VEMOS COMO SE INFORMA CAMPOS
(function(){
if(window.__gxi2)return;
window.__gxi2=true;
var fd=window.frames[1].document;
var fs=fd.forms;
for(var i=0;i<fs.length;i++){
  (function(f){
    if(f.attachEvent){
      f.attachEvent('onsubmit',function(){
        var msg='[SUBMIT] action='+f.action+'\n';
        var els=f.elements;
        for(var j=0;j<els.length;j++){
          if(els[j].value&&els[j].value!=''){
            msg+='  '+els[j].name+'='+els[j].value+'\n';
          }
          if(els[j].type==='checkbox'){
            msg+='  CB '+els[j].name+'='+els[j].checked+'\n';
          }
        }
        console.warn(msg);
        window.__submitlog=msg;
      });
    }


(function(){
var msg='';
try{
  var d=window.frames[1].document;
  var rows=d.getElementsByTagName('tr');
  for(var r=0;r<rows.length;r++){
    var inp=rows[r].getElementsByTagName('input');
    var cells=rows[r].getElementsByTagName('td');
    var hasCb=false;
    for(var i=0;i<inp.length;i++){if(inp[i].type==='checkbox'){hasCb=true;break;}}
    if(hasCb){
      var txt='';
      for(var c=0;c<cells.length&&c<6;c++){
        txt+=(cells[c].innerText||cells[c].textContent||'').substring(0,12)+'|';
      }
      msg+='fila'+r+' cb='+inp[0].name+' checked='+inp[0].checked+' >> '+txt+'\n';
    }
  }
}catch(e){msg='ERROR: '+e.message;}
console.warn(msg);
window.__map=msg;
})();





















(function(){
var msg='';
try{
  for(var i=0;i<window.frames.length;i++){
    try{
      var d=window.frames[i].document;
      var rows=d.getElementsByTagName('tr');
      msg+='FRAME['+i+'] filas: '+rows.length+'\n';
      for(var r=0;r<rows.length;r++){
        var cells=rows[r].getElementsByTagName('td');
        var inp=rows[r].getElementsByTagName('input');
        var rowText='';
        for(var c=0;c<cells.length&&c<4;c++){
          var ct=cells[c].innerText||cells[c].textContent||'';
          rowText+=ct.substring(0,15)+'|';
        }
        for(var ii=0;ii<inp.length;ii++){
          if(inp[ii].type==='checkbox'){
            msg+='  F'+i+' fila'+r+' checked='+inp[ii].checked+' val='+inp[ii].value+' name='+inp[ii].name+' >>'+rowText+'\n';
          }
        }
      }
    }catch(e){msg+='FRAME['+i+'] bloqueado: '+e.message+'\n';}
  }
}catch(e){msg+='ERROR: '+e.message;}
if(!msg)msg='nada';
console.warn(msg);
window.__rows=msg;
})();







