javascript:(function(){
  try{
    // 1. Leer checkboxes marcados REALES
    var seleccion = [];
    document.querySelectorAll('input[type="checkbox"]:checked').forEach(function(cb){
      // intenta sacar valor útil
      var val = cb.value || cb.getAttribute('data-value') || cb.id;
      if(val) seleccion.push(val);
    });

    // 2. Limpiar posibles caches típicos
    if(window.selectedItems) window.selectedItems = [];
    if(window.gx && gx.fn && gx.fn.setControlValue){
      // intenta limpiar hidden típico (ajusta nombre si lo ves en DOM)
      try{ gx.fn.setControlValue('vSELECCION',''); }catch(e){}
    }

    // 3. Reconstruir selección (string tipo 46,327,329)
    var lista = seleccion.join(',');

    console.log('✔ Selección limpia:', lista);

    // 4. Inyectar selección en el sistema (ajusta si ves otro campo hidden)
    try{
      var hidden = document.querySelector('input[type="hidden"]');
      if(hidden) hidden.value = lista;
    }catch(e){}

    // 5. Lanzar evento GeneXus
    if(typeof GX_setevent === 'function'){
      GX_setevent('ECONSULTA_CLICK', lista);
    }

  }catch(e){
    console.error('❌ Error:', e);
  }
})();






























(function(){
var R=[];
var SEP='--------------------------------------------------';
function t(s){R.push(SEP);R.push(s);R.push(SEP);}
function L(s){R.push(s);}

// 1. HIDDEN INPUTS
t('1. HIDDEN INPUTS');
var hids=document.getElementsByTagName('input');
var hidList=[];
for(var i=0;i<hids.length;i++){if(hids[i].type==='hidden')hidList.push(hids[i]);}
if(!hidList.length){L('(ninguno)');}
else{for(var i=0;i<hidList.length;i++){var h=hidList[i];L('name='+h.name+' id='+h.id+' val='+h.value);}}

// 2. CHECKBOXES
t('2. CHECKBOXES');
var cbs=[];
for(var i=0;i<hids.length;i++){if(hids[i].type==='checkbox')cbs.push(hids[i]);}
L('Total checkboxes: '+cbs.length);
for(var i=0;i<cbs.length;i++){
  var c=cbs[i];
  L('  cb id='+c.id+' name='+c.name+' val='+c.value+' checked='+c.checked+' onclick='+(c.getAttribute('onclick')||'')+ ' onchange='+(c.getAttribute('onchange')||''));
}

// 3. FORMULARIOS
t('3. FORMULARIOS');
var fs=document.forms;
L('Total forms: '+fs.length);
for(var i=0;i<fs.length;i++){
  var f=fs[i];
  L('Form['+i+'] id='+f.id+' name='+f.name+' action='+f.action);
  var els=f.elements;
  for(var j=0;j<els.length;j++){
    var el=els[j];
    if(el.type!=='checkbox'&&el.type!=='radio'&&el.value){
      L('  ['+el.type+'] name='+el.name+' val='+el.value.substring(0,100));
    }
  }
}

// 4. VARIABLES GLOBALES
t('4. VARIABLES GLOBALES');
var glist=['selectedRows','selectedItems','checkedItems','seleccionados','gxSelectedList','gxChecked','selectedIds','listaSeleccion','checkedRows','selectedValues','gxSelected','rowsSelected','itemsSelected','checkList','selList','gridSelected'];
var gfound=0;
for(var i=0;i<glist.length;i++){
  var g=glist[i];
  if(typeof window[g]!=='undefined'){
    gfound++;
    L('ENCONTRADA: '+g+' = '+JSON.stringify(window[g]).substring(0,150));
  }
}
if(!gfound)L('(ninguna del listado encontrada)');

// 5. FUNCIONES GX
t('5. FUNCIONES GENEXI');
var fnlist=['GX_setevent','gx_setevent','GXSetEvent','GXevt','doSubmit','ExecuteEvent','GxExecuteEvent','GxDoSubmit','GxSetGridValue','GxGetChecked'];
for(var i=0;i<fnlist.length;i++){
  var fn=fnlist[i];
  if(typeof window[fn]!=='undefined'){
    L('ENCONTRADA: window.'+fn+' ['+typeof window[fn]+']');
    if(typeof window[fn]==='function')L('  src: '+window[fn].toString().substring(0,200).replace(/\n/g,' '));
  }
}
var gxobjs=['gx','GX','gxobj','GXObject'];
for(var i=0;i<gxobjs.length;i++){
  var g=gxobjs[i];
  if(window[g]&&typeof window[g]==='object'){L('OBJETO GX: window.'+g+' existe');}
}

// 6. BOTONES
t('6. BOTONES');
var allInputs=document.getElementsByTagName('input');
var allBtns=document.getElementsByTagName('button');
var blist=[];
for(var i=0;i<allInputs.length;i++){if(allInputs[i].type==='button'||allInputs[i].type==='submit')blist.push(allInputs[i]);}
for(var i=0;i<allBtns.length;i++){blist.push(allBtns[i]);}
for(var i=0;i<blist.length;i++){
  var b=blist[i];
  var txt=(b.value||b.innerText||'').substring(0,40);
  var oc=b.getAttribute('onclick')||'';
  L('  btn id='+b.id+' txt='+txt+' onclick='+oc.substring(0,150));
}

// 7. SCRIPTS INLINE
t('7. SCRIPTS INLINE (fragmentos)');
var sc=document.getElementsByTagName('script');
var found=0;
for(var i=0;i<sc.length;i++){
  if(!sc[i].src){
    var txt=sc[i].text||sc[i].textContent||sc[i].innerText||'';
    var lines=txt.split('\n');
    for(var j=0;j<lines.length;j++){
      var ln=lines[j];
      if(/selected|checked|push|hidden|setevent|grid/i.test(ln)&&ln.trim().length>3){
        L('  script['+i+'] L'+j+': '+ln.trim().substring(0,130));
        found++;
        if(found>20)break;
      }
    }
  }
  if(found>20)break;
}
if(!found)L('(sin fragmentos relevantes)');

// 8. MONITOR HIDDENS
t('8. MONITOR ACTIVO EN HIDDENS');
var mon=0;
for(var i=0;i<hidList.length;i++){
  var h=hidList[i];
  if(!h.__mon){
    h.__mon=true;
    try{
      (function(el){
        var _v=el.value;
        Object.defineProperty(el,'value',{
          get:function(){return _v;},
          set:function(nv){
            if(nv!==_v)console.warn('[MON] hidden "'+el.name+'" '+_v+' >> '+nv);
            _v=nv;
          },
          configurable:true
        });
      })(h);
      mon++;
    }catch(e){L('  no se pudo monitorear: '+h.name+' ('+e.message+')');}
  }
}
L('Monitoreando '+mon+' hiddens. Marca checkboxes y pulsa Consultar ahora.');

// 9. INTERCEPTAR GX_setevent
t('9. INTERCEPTOR GX_setevent');
if(typeof window.GX_setevent==='function'&&!window.__gxi){
  var _o=window.GX_setevent;
  window.GX_setevent=function(){
    var args=[];
    for(var i=0;i<arguments.length;i++)args.push(arguments[i]);
    console.warn('[GX] GX_setevent llamado: '+args.join(' | '));
    return _o.apply(this,args);
  };
  window.__gxi=true;
  L('Interceptado. Proxima llamada aparecera en consola.');
}else if(window.__gxi){L('Ya interceptado.');}
else{L('GX_setevent no encontrado.');}

// SALIDA
L(SEP);
L('FIN. Ejecuta ahora:  copy(window.__diag)');
window.__diag=R.join('\n');
console.log(window.__diag);
})();
