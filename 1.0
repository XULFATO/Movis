// 1. RESET FUERTE
javascript:(function(){try{location.replace(location.href);}catch(e){location.reload(true);}}())

// 2. RESET NORMAL
javascript:(function(){try{window.location.href=window.location.href;}catch(e){location.reload();}}())

// 3. REFRESH INTERNO IE
javascript:(function(){try{document.execCommand('Refresh');}catch(e){location.reload();}}())

// 4. RESET SUAVE (FORM + FOCO)
javascript:(function(){try{if(document.forms&&document.forms[0]){document.forms[0].reset();}if(document.activeElement){document.activeElement.blur();}}catch(e){alert(e.message);}}())

// 5. CLICK FORZADO
javascript:(function(){try{var n=prompt('Nombre checkbox (ej: ACTUALIZA_0001)');if(!n)return;var x=document.getElementsByName(n);if(x&&x.length){x[0].click();}else{alert('No encontrado');}}catch(e){alert(e.message);}}())

